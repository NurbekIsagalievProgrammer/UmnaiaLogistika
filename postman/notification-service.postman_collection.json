{
  "info": {
    "name": "Notification Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Bulk SMS (critical)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Idempotency-Key", "value": "demo-bulk-1" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"sms\",\n  \"message\": \"Ваш код доступа: 1234\",\n  \"subscriber_ids\": [\"demo-sms\"],\n  \"priority\": \"critical\"\n}"
        },
        "url": "{{base_url}}/api/v1/notifications/bulk"
      }
    },
    {
      "name": "Subscriber notifications",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/subscribers/demo-sms/notifications"
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" }
  ]
}
